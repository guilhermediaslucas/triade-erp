# Modelo de variaveis de ambiente. Copie para .env e preencha.
# O .env real NUNCA vai para o GitHub (esta no .gitignore).

# Conexao do banco PostgreSQL (ex.: Neon)
DB_URL=postgresql://usuario:senha@host/banco?sslmode=require
# SSL: true para Neon/bancos gerenciados; false para Postgres local sem SSL
DB_SSL=true
# Porta da API
API_PORT=3333
# Segredo para assinar os tokens de login (use um valor longo e aleatorio)
JWT_SECRET=troque-por-um-valor-longo-e-aleatorio
# Ambiente: development | production
NODE_ENV=development

# --- Produção (nuvem) ---
# Em servicos como Render a porta vem em PORT automaticamente; nao precisa setar API_PORT.
# Origem permitida no CORS. Pode deixar * para comecar, ou restringir ao site:
# CORS_ORIGIN=https://seu-site.netlify.app
CORS_ORIGIN=*
# Ambiente:
NODE_ENV=production

# Aplica migrations + sincroniza permissoes no boot (produção). false desliga.
AUTO_MIGRATE=true

# --- E-mail transacional (Resend) ---
# Sem RESEND_API_KEY o envio vira no-op (loga e segue) — nada quebra.
# Chave criada no painel do Resend (resend.com).
RESEND_API_KEY=
# Remetente verificado no Resend (dominio triadeerp.com.br).
EMAIL_FROM=TRIADE ERP <notificacoes@triadeerp.com.br>
# Destino das notificacoes de suporte (encaminhado ao Gmail via Cloudflare Email Routing).
SUPORTE_EMAIL_DESTINO=admin@triadeerp.com.br
# URL publica do site (frontend) — base do link de redefinicao de senha.
APP_URL=https://triadeerp.com.br
