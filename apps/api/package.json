{
  "name": "@triade/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "start:prod": "tsx src/main.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/infra/db/cli.ts migrate",
    "db:seed": "tsx src/infra/db/cli.ts seed"
  },
  "dependencies": {
    "@triade/shared": "*",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "tsx": "^4.19.2",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  }
}
